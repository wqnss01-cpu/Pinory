NODE_ENV=production
PORT=4000
# Northflank заполняет адрес автоматически через NF_HOSTS.
# Для другого хостинга раскомментируйте и укажите один HTTPS-домен:
# PUBLIC_API_URL=https://app.example.com/api/v1
# CORS_ORIGINS=https://app.example.com

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_SSL=true
DB_POOL_MAX=5

JWT_SECRET=GENERATE_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS
SESSION_TTL_MINUTES=30

TELEGRAM_BOT_TOKEN=PASTE_TOKEN_FROM_BOTFATHER
# TELEGRAM_MINI_APP_URL=https://app.example.com
TELEGRAM_WEBHOOK_SECRET=GENERATE_A_RANDOM_SECRET_USING_LETTERS_NUMBERS_DASH_UNDERSCORE
ALLOW_DEV_TELEGRAM=false

GEOCODING_URL=https://nominatim.openstreetmap.org/search
GEOCODING_USER_AGENT=Pinory/1.0 (your-real-email@example.com)

S3_ENDPOINT=https://YOUR_SUPABASE_PROJECT_REF.storage.supabase.co/storage/v1/s3
S3_REGION=YOUR_SUPABASE_PROJECT_REGION
S3_ACCESS_KEY=SUPABASE_S3_ACCESS_KEY_ID
S3_SECRET_KEY=SUPABASE_S3_SECRET_ACCESS_KEY
S3_BUCKET=pinory-media
S3_PUBLIC_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co/storage/v1/object/public/pinory-media
S3_FORCE_PATH_STYLE=true
S3_AUTO_CREATE_BUCKET=false
S3_SET_PUBLIC_POLICY=false

ADMIN_TELEGRAM_IDS=YOUR_NUMERIC_TELEGRAM_ID
ENABLE_API_DOCS=false
