NODE_ENV=production
PORT=8000
PUBLIC_API_URL=https://YOUR-API.koyeb.app/api/v1
CORS_ORIGINS=https://YOUR-PROJECT.pages.dev

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_SSL=true
DB_POOL_MAX=5

JWT_SECRET=GENERATE_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS
SESSION_TTL_MINUTES=30

TELEGRAM_BOT_TOKEN=PASTE_TOKEN_FROM_BOTFATHER
TELEGRAM_MINI_APP_URL=https://YOUR-PROJECT.pages.dev
TELEGRAM_WEBHOOK_SECRET=GENERATE_A_RANDOM_SECRET_USING_LETTERS_NUMBERS_DASH_UNDERSCORE
ALLOW_DEV_TELEGRAM=false

GEOCODING_URL=https://nominatim.openstreetmap.org/search
GEOCODING_USER_AGENT=Pinory/1.0 (your-real-email@example.com)

S3_ENDPOINT=https://YOUR_CLOUDFLARE_ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=R2_ACCESS_KEY_ID
S3_SECRET_KEY=R2_SECRET_ACCESS_KEY
S3_BUCKET=pinory-media
S3_PUBLIC_URL=https://YOUR_PUBLIC_R2_DOMAIN
S3_FORCE_PATH_STYLE=true
S3_AUTO_CREATE_BUCKET=false
S3_SET_PUBLIC_POLICY=false

ADMIN_TELEGRAM_IDS=YOUR_NUMERIC_TELEGRAM_ID
ENABLE_API_DOCS=false
