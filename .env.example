NODE_ENV=development
API_PORT=4000
MINIAPP_PORT=5173
PUBLIC_API_URL=http://localhost:4000/api/v1
CORS_ORIGINS=http://localhost:5173

DATABASE_URL=postgresql://pinory:pinory@localhost:5432/pinory
DATABASE_SSL=false
DB_POOL_MAX=5
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-at-least-32-random-characters
SESSION_TTL_MINUTES=30

TELEGRAM_BOT_TOKEN=
TELEGRAM_MINI_APP_URL=http://localhost:5173
TELEGRAM_WEBHOOK_SECRET=
ALLOW_DEV_TELEGRAM=false
# Только для локальной разработки вне Telegram. Значения не создают демо-контент.
DEV_TELEGRAM_USER_ID=
DEV_TELEGRAM_FIRST_NAME=Разработчик
DEV_TELEGRAM_USERNAME=

GEOCODING_URL=https://nominatim.openstreetmap.org/search
GEOCODING_USER_AGENT=Pinory/1.0 (your-real-email@example.com)
MAP_STYLE_URL=
MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=pinory
S3_SECRET_KEY=pinory-secret
S3_BUCKET=pinory-media
S3_PUBLIC_URL=http://localhost:9000/pinory-media
S3_FORCE_PATH_STYLE=true
S3_AUTO_CREATE_BUCKET=true
S3_SET_PUBLIC_POLICY=true

ADMIN_TELEGRAM_IDS=
ENABLE_API_DOCS=false

VITE_API_URL=http://localhost:4000/api/v1
VITE_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
