<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#17352E</item>
        <item name="colorPrimaryDark">#13231F</item>
        <item name="colorAccent">#FF735C</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:navigationBarColor">#F6F0E4</item>
        <item name="android:statusBarColor">#F6F0E4</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/pinory_splash</item>
        <item name="windowSplashScreenBackground">#F6F0E4</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/pinory_launcher</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
