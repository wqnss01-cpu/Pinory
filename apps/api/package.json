    "db:clear-content": "tsx src/scripts/clear-content.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.850.0",
    "@fastify/cors": "^10.1.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^10.1.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@pinory/config": "1.0.0",
    "@pinory/shared": "1.0.0",
    "dotenv": "^17.2.0",
    "fastify": "^5.4.0",
    "grammy": "^1.36.3",
    "ioredis": "^5.6.1",
    "pg": "^8.16.3",
    "sharp": "^0.34.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/pg": "^8.15.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
